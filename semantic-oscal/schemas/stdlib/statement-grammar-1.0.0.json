{
  "id": "https://ns.oscal.org/stdlib/facet/statement-grammar",
  "version": "1.0.0",
  "modifies-semantics": [],
  "note": "NORMATIVE (gate item 2). Chrome-for-computation confirmed (D.12 audit): the grammar decomposition serves authoring and QA; assessment semantics live in assessment-criteria@1. Per-clause payloads MUST use the by-statement keying (D10 rev, backlog #7): a key naming no statement of the host is a validation error.",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object", "additionalProperties": false,
    "properties": {
      "by-statement": {
        "type": "object", "minProperties": 1,
        "additionalProperties": {
          "type": "object", "additionalProperties": false,
          "properties": {
            "action": { "type": "string" },
            "action-word": { "type": "string" },
            "result": { "type": "string" },
            "result-specification": { "type": "string" },
            "target-object-categories": { "type": "array", "items": { "type": "string" } },
            "practice": { "type": "string" }
          }
        }
      }
    },
    "required": ["by-statement"]
  }
}
