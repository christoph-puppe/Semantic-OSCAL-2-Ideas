{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://ns.oscal.org/semantic-core/schema/1.0.0",
 "title": "OSCAL Semantic Core - normative kernel shapes (gate item 2)",
 "description": "The nine kernel types + Deviation sub-object + content manifest, field by field per Handbook Appendix A / spec Appendix A. Kernel shapes are CLOSED (unevaluatedProperties: false): an unknown top-level field is a validation error - facets are the extension surface (D10). Objects carry no type discriminator; a conformant object matches EXACTLY ONE of the nine type entry points (shape-disjointness is itself a conformance property, exercised by the conformance corpus).",
 "$defs": {
  "uri": {
   "type": "string",
   "minLength": 1
  },
  "digest": {
   "type": "string",
   "pattern": "^sha256:[0-9a-f]{64}$"
  },
  "text": {
   "type": "object",
   "minProperties": 1,
   "propertyNames": {
    "pattern": "^[a-z]{2,3}(-[a-z0-9]{1,8})*$"
   },
   "additionalProperties": {
    "anyOf": [
     {
      "type": "string",
      "minLength": 1
     },
     {
      "type": "array",
      "minItems": 1,
      "items": {
       "type": "string",
       "minLength": 1
      }
     }
    ]
   }
  },
  "predicate": {
   "anyOf": [
    {
     "type": "object",
     "additionalProperties": false,
     "required": [
      "field-equals"
     ],
     "properties": {
      "field-equals": {
       "type": "object",
       "additionalProperties": false,
       "required": [
        "path",
        "value"
       ],
       "properties": {
        "path": {
         "type": "string",
         "minLength": 1
        },
        "value": {}
       }
      }
     }
    },
    {
     "type": "object",
     "additionalProperties": false,
     "required": [
      "param-equals"
     ],
     "properties": {
      "param-equals": {
       "type": "object",
       "additionalProperties": false,
       "required": [
        "name",
        "value"
       ],
       "properties": {
        "name": {
         "type": "string",
         "minLength": 1
        },
        "value": {}
       }
      }
     }
    },
    {
     "type": "object",
     "additionalProperties": false,
     "required": [
      "present"
     ],
     "properties": {
      "present": {
       "type": "object",
       "additionalProperties": false,
       "required": [
        "path"
       ],
       "properties": {
        "path": {
         "type": "string",
         "minLength": 1
        }
       }
      }
     }
    }
   ]
  },
  "modality": {
   "enum": [
    "unspecified",
    "may",
    "should",
    "must",
    "may-only",
    "should-not",
    "must-not"
   ]
  },
  "lifecycle": {
   "enum": [
    "draft",
    "active",
    "deprecated",
    "withdrawn"
   ]
  },
  "findingState": {
   "enum": [
    "open",
    "in-remediation",
    "closed"
   ]
  },
  "deviationType": {
   "enum": [
    "false-positive",
    "operational-requirement",
    "risk-adjustment",
    "vendor-dependency",
    "derogation"
   ]
  },
  "deviationState": {
   "enum": [
    "investigating",
    "pending",
    "approved",
    "withdrawn"
   ]
  },
  "responsibility": {
   "enum": [
    "provider",
    "customer",
    "shared",
    "inherited"
   ]
  },
  "mappingRelationship": {
   "enum": [
    "equal",
    "subset-of",
    "superset-of",
    "intersects",
    "supports",
    "conflicts",
    "supplements"
   ]
  },
  "mappingDirection": {
   "enum": [
    "source-to-target",
    "bidirectional"
   ]
  },
  "confidence": {
   "enum": [
    "draft",
    "reviewed",
    "authoritative"
   ]
  },
  "componentKind": {
   "enum": [
    "system",
    "service",
    "software",
    "hardware",
    "policy",
    "process"
   ]
  },
  "implementationStatus": {
   "enum": [
    "planned",
    "partial",
    "implemented",
    "not-applicable"
   ]
  },
  "assessmentResult": {
   "enum": [
    "satisfied",
    "not-satisfied",
    "inconclusive"
   ]
  },
  "elapsedUnit": {
   "enum": [
    "seconds",
    "minutes",
    "hours"
   ]
  },
  "calendarUnit": {
   "enum": [
    "days",
    "bizdays",
    "weeks",
    "months",
    "years"
   ]
  },
  "tightening": {
   "enum": [
    "lower",
    "higher",
    "none"
   ]
  },
  "decimalString": {
   "type": "string",
   "pattern": "^(-?[1-9][0-9]*(\\.[0-9]+)?|0(\\.[0-9]+)?|-0\\.[0-9]*[1-9][0-9]*)$"
  },
  "alias": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "scheme",
    "value"
   ],
   "properties": {
    "scheme": {
     "type": "string"
    },
    "value": {
     "type": "string"
    }
   }
  },
  "relation": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "type",
    "ref"
   ],
   "properties": {
    "type": {
     "anyOf": [
      {
       "enum": [
        "related",
        "required",
        "uses-term",
        "reference",
        "schema"
       ]
      },
      {
       "type": "string",
       "pattern": "^https?://."
      }
     ]
    },
    "ref": {
     "$ref": "#/$defs/uri"
    }
   }
  },
  "base": {
   "type": "object",
   "required": [
    "id",
    "version",
    "lifecycle"
   ],
   "properties": {
    "id": {
     "$ref": "#/$defs/uri"
    },
    "version": {
     "type": "string",
     "minLength": 1
    },
    "label": {
     "type": "string"
    },
    "title": {
     "$ref": "#/$defs/text"
    },
    "aliases": {
     "type": "array",
     "minItems": 1,
     "items": {
      "$ref": "#/$defs/alias"
     }
    },
    "lifecycle": {
     "$ref": "#/$defs/lifecycle"
    },
    "canonical-alias": {
     "type": "array",
     "minItems": 1,
     "items": {
      "type": "object",
      "additionalProperties": false,
      "required": [
       "of"
      ],
      "properties": {
       "of": {
        "$ref": "#/$defs/uri"
       }
      }
     }
    },
    "replaces": {
     "type": "array",
     "minItems": 1,
     "items": {
      "type": "object",
      "additionalProperties": false,
      "required": [
       "ref",
       "mode"
      ],
      "properties": {
       "ref": {
        "$ref": "#/$defs/uri"
       },
       "mode": {
        "enum": [
         "revised",
         "split-from",
         "merged-into",
         "renamed"
        ]
       }
      }
     }
    },
    "relations": {
     "type": "array",
     "minItems": 1,
     "items": {
      "$ref": "#/$defs/relation"
     }
    },
    "facets": {
     "type": "object",
     "minProperties": 1,
     "propertyNames": {
      "pattern": "@[0-9]+$"
     },
     "additionalProperties": {
      "type": "object"
     }
    },
    "annotations": {
     "type": "object",
     "minProperties": 1
    }
   }
  },
  "parameter": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "name",
    "type"
   ],
   "properties": {
    "name": {
     "type": "string",
     "minLength": 1
    },
    "type": {
     "enum": [
      "string",
      "integer",
      "decimal",
      "boolean",
      "date",
      "datetime",
      "uri",
      "code",
      "choice",
      "list",
      "range",
      "elapsed-duration",
      "calendar-period"
     ]
    },
    "label": {
     "type": "string"
    },
    "default": {},
    "tightening": {
     "$ref": "#/$defs/tightening"
    },
    "choices": {
     "type": "array",
     "minItems": 1,
     "items": {
      "type": "object",
      "additionalProperties": false,
      "required": [
       "value"
      ],
      "properties": {
       "value": {},
       "label": {
        "$ref": "#/$defs/text"
       }
      }
     }
    },
    "cardinality": {
     "enum": [
      "one",
      "many"
     ]
    },
    "min": {
     "type": "number"
    },
    "max": {
     "type": "number"
    },
    "num": {
     "type": "number"
    },
    "unit": {
     "type": "string"
    },
    "calendar-ref": {
     "$ref": "#/$defs/uri"
    },
    "timezone": {
     "type": "string"
    },
    "cutoff": {
     "type": "string"
    }
   },
   "allOf": [
    {
     "if": {
      "properties": {
       "type": {
        "const": "elapsed-duration"
       }
      },
      "required": [
       "type"
      ]
     },
     "then": {
      "required": [
       "num",
       "unit"
      ],
      "properties": {
       "unit": {
        "$ref": "#/$defs/elapsedUnit"
       }
      }
     }
    },
    {
     "if": {
      "properties": {
       "type": {
        "const": "calendar-period"
       }
      },
      "required": [
       "type"
      ]
     },
     "then": {
      "required": [
       "num",
       "unit",
       "calendar-ref"
      ],
      "properties": {
       "unit": {
        "$ref": "#/$defs/calendarUnit"
       }
      }
     }
    },
    {
     "if": {
      "properties": {
       "type": {
        "const": "choice"
       }
      },
      "required": [
       "type"
      ]
     },
     "then": {
      "required": [
       "choices"
      ]
     }
    },
    {
     "if": {
      "properties": {
       "type": {
        "const": "decimal"
       }
      },
      "required": [
       "type"
      ]
     },
     "then": {
      "properties": {
       "default": {
        "$ref": "#/$defs/decimalString"
       }
      }
     }
    }
   ]
  },
  "statement": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "id",
    "modality",
    "obligated-parties",
    "prose"
   ],
   "properties": {
    "id": {
     "type": "string",
     "minLength": 1
    },
    "modality": {
     "$ref": "#/$defs/modality"
    },
    "obligated-parties": {
     "type": "array",
     "minItems": 1,
     "items": {
      "$ref": "#/$defs/uri"
     }
    },
    "parameters": {
     "type": "array",
     "minItems": 1,
     "items": {
      "$ref": "#/$defs/parameter"
     }
    },
    "prose": {
     "$ref": "#/$defs/text"
    }
   }
  },
  "deviation": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "type",
    "state",
    "rationale",
    "approver-ref",
    "opened"
   ],
   "properties": {
    "type": {
     "$ref": "#/$defs/deviationType"
    },
    "state": {
     "$ref": "#/$defs/deviationState"
    },
    "rationale": {
     "$ref": "#/$defs/text"
    },
    "approver-ref": {
     "$ref": "#/$defs/uri"
    },
    "opened": {
     "type": "string",
     "minLength": 1
    },
    "refs": {
     "type": "array",
     "minItems": 1,
     "items": {
      "$ref": "#/$defs/uri"
     }
    }
   }
  },
  "operation": {
   "type": "object",
   "additionalProperties": false,
   "required": [
    "op",
    "requirement-ref"
   ],
   "properties": {
    "op": {
     "enum": [
      "set-parameter",
      "set-modality",
      "set-field",
      "replace-prose",
      "add-relation",
      "remove-relation",
      "attach-facet",
      "detach-facet"
     ]
    },
    "requirement-ref": {
     "$ref": "#/$defs/uri"
    },
    "statement-id": {
     "type": "string"
    },
    "parameter": {
     "type": "string"
    },
    "value": {},
    "modality": {
     "$ref": "#/$defs/modality"
    },
    "field": {
     "type": "string"
    },
    "prose": {
     "$ref": "#/$defs/text"
    },
    "intent": {
     "enum": [
      "editorial",
      "substantive"
     ]
    },
    "relation": {
     "$ref": "#/$defs/relation"
    },
    "facet": {
     "type": "string"
    },
    "payload": {},
    "override": {
     "$ref": "#/$defs/uri"
    },
    "deviation": {
     "$ref": "#/$defs/deviation"
    },
    "deviation-ref": {
     "type": "string"
    }
   },
   "allOf": [
    {
     "if": {
      "properties": {
       "op": {
        "const": "set-parameter"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "parameter",
       "value"
      ]
     }
    },
    {
     "if": {
      "properties": {
       "op": {
        "const": "set-modality"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "modality"
      ]
     }
    },
    {
     "if": {
      "properties": {
       "op": {
        "const": "replace-prose"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "prose",
       "intent"
      ]
     }
    },
    {
     "if": {
      "properties": {
       "op": {
        "const": "set-field"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "field",
       "value"
      ],
      "properties": {
       "field": {
        "enum": [
         "title",
         "label",
         "annotations"
        ]
       }
      }
     }
    },
    {
     "if": {
      "properties": {
       "op": {
        "const": "attach-facet"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "facet",
       "payload"
      ]
     }
    },
    {
     "if": {
      "properties": {
       "op": {
        "const": "detach-facet"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "facet"
      ]
     }
    },
    {
     "if": {
      "properties": {
       "op": {
        "const": "add-relation"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "relation"
      ]
     }
    },
    {
     "if": {
      "properties": {
       "op": {
        "const": "remove-relation"
       }
      },
      "required": [
       "op"
      ]
     },
     "then": {
      "required": [
       "relation"
      ]
     }
    }
   ]
  },
  "requirement": {
   "allOf": [
    {
     "$ref": "#/$defs/base"
    },
    {
     "required": [
      "statements"
     ],
     "properties": {
      "statements": {
       "type": "array",
       "minItems": 1,
       "items": {
        "$ref": "#/$defs/statement"
       }
      },
      "deviations": {
       "type": "array",
       "minItems": 1,
       "items": {
        "$ref": "#/$defs/deviation"
       }
      }
     }
    }
   ],
   "unevaluatedProperties": false
  },
  "requirementSet": {
   "allOf": [
    {
     "$ref": "#/$defs/base"
    },
    {
     "required": [
      "members"
     ],
     "properties": {
      "members": {
       "type": "array",
       "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
         "ref"
        ],
        "properties": {
         "ref": {
          "$ref": "#/$defs/uri"
         },
         "sequence": {
          "type": "integer"
         }
        }
       }
      }
     }
    }
   ],
   "unevaluatedProperties": false
  },
  "tailoring": {
   "allOf": [
    {
     "$ref": "#/$defs/base"
    },
    {
     "required": [
      "selects"
     ],
     "properties": {
      "selects": {
       "type": "array",
       "minItems": 1,
       "items": {
        "anyOf": [
         {
          "type": "object",
          "additionalProperties": false,
          "required": [
           "set-ref"
          ],
          "properties": {
           "set-ref": {
            "$ref": "#/$defs/uri"
           }
          }
         },
         {
          "type": "object",
          "additionalProperties": false,
          "required": [
           "predicate"
          ],
          "properties": {
           "predicate": {
            "$ref": "#/$defs/predicate"
           }
          }
         }
        ]
       }
      },
      "excludes": {
       "type": "array",
       "minItems": 1,
       "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
         "ref"
        ],
        "properties": {
         "ref": {
          "$ref": "#/$defs/uri"
         },
         "rationale": {
          "$ref": "#/$defs/text"
         }
        }
       }
      },
      "operations": {
       "type": "array",
       "items": {
        "$ref": "#/$defs/operation"
       }
      },
      "deviations": {
       "type": "array",
       "minItems": 1,
       "items": {
        "$ref": "#/$defs/deviation"
       }
      }
     }
    }
   ],
   "unevaluatedProperties": false
  },
  "mapping": {
   "allOf": [
    {
     "$ref": "#/$defs/base"
    },
    {
     "required": [
      "source-ref",
      "target-ref",
      "relationship",
      "direction",
      "confidence",
      "provenance"
     ],
     "properties": {
      "source-ref": {
       "$ref": "#/$defs/uri"
      },
      "target-ref": {
       "$ref": "#/$defs/uri"
      },
      "source-scope": {
       "type": "array",
       "minItems": 1,
       "items": {
        "type": "string",
        "pattern": "^statement:"
       }
      },
      "target-scope": {
       "type": "array",
       "minItems": 1,
       "items": {
        "type": "string",
        "pattern": "^statement:"
       }
      },
      "relationship": {
       "$ref": "#/$defs/mappingRelationship"
      },
      "direction": {
       "$ref": "#/$defs/mappingDirection"
      },
      "confidence": {
       "$ref": "#/$defs/confidence"
      },
      "rationale": {
       "$ref": "#/$defs/text"
      },
      "provenance": {
       "type": "object",
       "additionalProperties": false,
       "required": [
        "author-ref",
        "date"
       ],
       "properties": {
        "author-ref": {
         "$ref": "#/$defs/uri"
        },
        "date": {
         "type": "string",
         "minLength": 1
        }
       }
      },
      "evidence-refs": {
       "type": "array",
       "minItems": 1,
       "items": {
        "$ref": "#/$defs/uri"
       }
      }
     }
    }
   ],
   "unevaluatedProperties": false
  },
  "component": {
   "allOf": [
    {
     "$ref": "#/$defs/base"
    },
    {
     "required": [
      "kind"
     ],
     "properties": {
      "kind": {
       "$ref": "#/$defs/componentKind"
      },
      "members": {
       "type": "array",
       "minItems": 1,
       "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
         "component-ref"
        ],
        "properties": {
         "component-ref": {
          "$ref": "#/$defs/uri"
         },
         "context": {
          "type": "string"
         }
        }
       }
      },
      "capabilities": {
       "type": "array",
       "minItems": 1,
       "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
         "id"
        ],
        "properties": {
         "id": {
          "type": "string"
         },
         "requirement-ref": {
          "$ref": "#/$defs/uri"
         },
         "description": {
          "$ref": "#/$defs/text"
         },
         "parameter-bindings": {
          "type": "object"
         }
        }
       }
      },
      "authorizations": {
       "type": "array",
       "minItems": 1,
       "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
         "id",
         "authority-ref"
        ],
        "properties": {
         "id": {
          "type": "string"
         },
         "authority-ref": {
          "$ref": "#/$defs/uri"
         },
         "scope-label": {
          "type": "string"
         },
         "includes": {
          "type": "array",
          "items": {
           "$ref": "#/$defs/uri"
          }
         }
        }
       }
      }
     }
    }
   ],
   "unevaluatedProperties": false
  },
  "implementation": {
   "allOf": [
    {
     "$ref": "#/$defs/base"
    },
    {
     "required": [
      "component-ref",
      "requirement-ref",
      "responsibility",
      "satisfied-by",
      "status"
     ],
     "properties": {
      "component-ref": {
       "$ref": "#/$defs/uri"
      },
      "requirement-ref": {
       "$ref": "#/$defs/uri"
      },
      "statement-refs": {
       "type": "array",
       "minItems": 1,
       "items": {
        "type": "string"
       }
      },
      "responsibility": {
       "$ref": "#/$defs/responsibility"
      },
      "satisfied-by": {
       "type": "array",
       "minItems": 1,
       "items": {
        "anyOf": [
         {
