{
 "id": "https://ns.nist.gov/sp800-53/req/AU-12",
 "version": "5.2.0",
 "label": "AU-12",
 "lifecycle": "active",
 "title": {
  "en": "Audit Record Generation"
 },
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Provide audit record generation capability for the event types the system is capable of auditing as defined in AU-2a on {param:au-12_odp.01};"
   },
   "parameters": [
    {
     "name": "au-12_odp.01",
     "type": "string",
     "label": "system components"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Allow {param:au-12_odp.02} to select the event types that are to be logged by specific components of the system; and"
   },
   "parameters": [
    {
     "name": "au-12_odp.02",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Generate audit records for the event types defined in AU-2c that include the audit record content defined in AU-3."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Audit records can be generated from many different system components. The event types specified in AU-2d are the event types for which audit logs are to be generated and are a subset of all event types for which the system can generate audit records."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "au-12_obj",
     "label": "AU-12",
     "children": [
      {
       "id": "au-12_obj.a",
       "label": "AU-12a.",
       "prose": {
        "en": "audit record generation capability for the event types the system is capable of auditing (defined in AU-02_ODP[01]) is provided by {param:au-12_odp.01};"
       }
      },
      {
       "id": "au-12_obj.b",
       "label": "AU-12b.",
       "prose": {
        "en": "{param:au-12_odp.02} is/are allowed to select the event types that are to be logged by specific components of the system;"
       }
      },
      {
       "id": "au-12_obj.c",
       "label": "AU-12c.",
       "prose": {
        "en": "audit records for the event types defined in AU-02_ODP[02] that include the audit record content defined in AU-03 are generated."
       }
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "AU-12-Examine",
     "objects": [
      {
       "en": "Audit and accountability policy"
      },
      {
       "en": "procedures addressing audit record generation"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "privacy plan"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "list of auditable events"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "AU-12-Interview",
     "objects": [
      {
       "en": "Organizational personnel with audit record generation responsibilities"
      },
      {
       "en": "organizational personnel with information security and privacy responsibilities"
      },
      {
       "en": "system/network administrators"
      },
      {
       "en": "system developers"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "AU-12-Test",
     "objects": [
      {
       "en": "Mechanisms implementing audit record generation capability"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
    "au-12_odp.01": {
     "guidelines": [
      {
       "en": "system components that provide an audit record generation capability for the events types (defined in AU-02_ODP[02]) are defined;"
      }
     ],
     "alt-identifiers": [
      "au-12_prm_1"
     ]
    },
    "au-12_odp.02": {
     "guidelines": [
      {
       "en": "personnel or roles allowed to select the event types that are to be logged by specific components of the system is/are defined;"
      }
     ],
     "alt-identifiers": [
      "au-12_prm_2"
     ]
    }
   }
  }
 },
