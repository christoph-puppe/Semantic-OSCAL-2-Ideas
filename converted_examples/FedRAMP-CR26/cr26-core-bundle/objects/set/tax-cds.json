 "facets": {
  "https://ns.fedramp.gov/cr26/facet/narrative@1": {
   "description": "The Certification Data Sharing rules allow providers to store and share FedRAMP Certification Data through the platform they choose as long as it follows FedRAMP rules for access, accuracy, and transparency. This helps customers and the public review consistent, current security and compliance information while recognizing that the information usually remains the provider's intellectual property and is not federal information."
  },
