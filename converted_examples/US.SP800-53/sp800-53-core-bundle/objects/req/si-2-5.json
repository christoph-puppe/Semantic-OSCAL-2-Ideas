 "title": "Automatic Software and Firmware Updates",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Install {param:si-02.05_odp.01} automatically to {param:si-02.05_odp.02}."
   },
   "parameters": [
    {
     "name": "si-02.05_odp.01",
     "type": "string",
     "label": "security-relevant software and firmware updates"
    },
    {
     "name": "si-02.05_odp.02",
     "type": "string",
     "label": "system components"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Due to system integrity and availability concerns, organizations consider the methodology used to carry out automatic updates. Organizations balance the need to ensure that the updates are installed as soon as possible with the need to maintain configuration management and control with any mission or operational impacts that automatic updates might impose (i.e., implementing a staggered deployment strategy)."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
