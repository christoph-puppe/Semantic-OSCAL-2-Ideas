 "title": "Unauthorized Network Services",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Detect network services that have not been authorized or approved by {param:si-04.22_odp.01} ; and"
   },
   "parameters": [
    {
     "name": "si-04.22_odp.01",
     "type": "string",
     "label": "authorization or approval processes"
    },
    {
     "name": "si-04.22_odp.03",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "{param:si-04.22_odp.02} when detected."
   },
   "parameters": [
    {
     "name": "si-04.22_odp.02",
     "type": "choice",
     "choices": [
      {
       "value": "audit"
      },
      {
       "value": "alert {param:si-04.22_odp.03} "
      }
     ],
     "cardinality": "many"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Unauthorized or unapproved network services include services in service-oriented architectures that lack organizational verification or validation and may therefore be unreliable or serve as malicious rogues for valid services."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "si-4.22_obj",
     "label": "SI-04(22)",
     "children": [
      {
       "id": "si-4.22_obj.a",
       "label": "SI-04(22)(a)",
       "prose": {
        "en": "network services that have not been authorized or approved by {param:si-04.22_odp.01} are detected;"
       }
      },
      {
       "id": "si-4.22_obj.b",
       "label": "SI-04(22)(b)",
       "prose": {
        "en": "{param:si-04.22_odp.02} is/are initiated when network services that have not been authorized or approved by authorization or approval processes are detected."
       }
      }
     ]
    }
   ],
