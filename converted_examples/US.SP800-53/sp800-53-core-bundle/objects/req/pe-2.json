 "label": "PE-2",
 "lifecycle": "active",
 "title": "Physical Access Authorizations",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Develop, approve, and maintain a list of individuals with authorized access to the facility where the system resides;"
   }
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Issue authorization credentials for facility access;"
   }
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Review the access list detailing authorized facility access by individuals {param:pe-02_odp} ; and"
   },
   "parameters": [
    {
     "name": "pe-02_odp",
     "type": "string",
     "label": "frequency"
    }
   ]
  },
  {
   "id": "smt.d",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Remove individuals from the facility access list when access is no longer required."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Physical access authorizations apply to employees and visitors. Individuals with permanent physical access authorization credentials are not considered visitors. Authorization credentials include ID badges, identification cards, and smart cards. Organizations determine the strength of authorization credentials needed consistent with applicable laws, executive orders, directives, regulations, policies, standards, and guidelines. Physical access authorizations may not be necessary to access certain areas within facilities that are designated as publicly accessible."
    }
   ]
  },
