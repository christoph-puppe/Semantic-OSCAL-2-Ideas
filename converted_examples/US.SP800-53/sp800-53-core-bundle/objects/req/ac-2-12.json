 "label": "AC-2(12)",
 "lifecycle": "active",
 "title": "Account Monitoring for Atypical Usage",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Monitor system accounts for {param:ac-02.12_odp.01} ; and"
   },
   "parameters": [
    {
     "name": "ac-02.12_odp.01",
     "type": "string",
     "label": "atypical usage"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Report atypical usage of system accounts to {param:ac-02.12_odp.02}."
   },
   "parameters": [
    {
     "name": "ac-02.12_odp.02",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Atypical usage includes accessing systems at certain times of the day or from locations that are not consistent with the normal usage patterns of individuals. Monitoring for atypical usage may reveal rogue behavior by individuals or an attack in progress. Account monitoring may inadvertently create privacy risks since data collected to identify atypical usage may reveal previously unknown information about the behavior of individuals. Organizations assess and document privacy risks from monitoring accounts for atypical usage in their privacy impact assessment and make determinations that are in alignment with their privacy program plan."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ac-2.12_obj",
     "label": "AC-02(12)",
     "children": [
      {
       "id": "ac-2.12_obj.a",
       "label": "AC-02(12)(a)",
       "prose": {
        "en": "system accounts are monitored for {param:ac-02.12_odp.01}; "
       }
      },
      {
       "id": "ac-2.12_obj.b",
       "label": "AC-02(12)(b)",
       "prose": {
        "en": "atypical usage of system accounts is reported to {param:ac-02.12_odp.02}."
       }
      }
     ]
    }
   ],
   "methods": [
