 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Approaches for dynamically creating, activating, managing, and deactivating system accounts rely on automatically provisioning the accounts at runtime for entities that were previously unknown. Organizations plan for the dynamic management, creation, activation, and deactivation of system accounts by establishing trust relationships, business rules, and mechanisms with appropriate authorities to validate related authorizations and privileges."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
