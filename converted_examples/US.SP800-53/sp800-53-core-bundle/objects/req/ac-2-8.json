   "prose": {
    "en": "Create, activate, manage, and deactivate {param:ac-02.08_odp} dynamically."
   },
   "parameters": [
    {
     "name": "ac-02.08_odp",
     "type": "string",
     "label": "system accounts"
    }
   ]
  }
