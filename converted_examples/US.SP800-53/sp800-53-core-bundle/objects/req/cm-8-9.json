       "id": "cm-8.9_obj.a",
       "label": "CM-08(09)(a)",
       "prose": {
        "en": "system components are assigned to a system;"
       }
      },
      {
       "id": "cm-8.9_obj.b",
       "label": "CM-08(09)(b)",
       "prose": {
        "en": "an acknowledgement of the component assignment is received from {param:cm-08.09_odp}."
       }
      }
     ]
    }
   ],
