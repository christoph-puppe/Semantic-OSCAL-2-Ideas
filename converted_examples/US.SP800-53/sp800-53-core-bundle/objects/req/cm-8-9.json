    "en": "Receive an acknowledgement from {param:cm-08.09_odp} of this assignment."
   },
   "parameters": [
    {
     "name": "cm-08.09_odp",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "System components that are not assigned to a system may be unmanaged, lack the required protection, and become an organizational vulnerability."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
