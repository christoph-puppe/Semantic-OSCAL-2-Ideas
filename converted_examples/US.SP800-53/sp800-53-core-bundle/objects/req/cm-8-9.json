   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Assign system components to a system; and"
   }
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
