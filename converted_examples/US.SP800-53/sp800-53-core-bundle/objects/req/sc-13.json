  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Implement the following types of cryptography required for each specified cryptographic use: {param:sc-13_odp.02}."
   },
