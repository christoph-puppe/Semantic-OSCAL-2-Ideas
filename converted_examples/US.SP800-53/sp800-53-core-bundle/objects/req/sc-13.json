       }
      },
      {
       "id": "sc-13_obj.b",
       "label": "SC-13b.",
       "prose": {
        "en": "{param:sc-13_odp.02} for each specified cryptographic use (defined in SC-13_ODP[01]) are implemented."
       }
      }
     ]
    }
   ],
