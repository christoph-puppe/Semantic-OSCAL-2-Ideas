    {
     "id": "ir-4.9_obj",
     "label": "IR-04(09)",
     "prose": {
      "en": "{param:ir-04.09_odp} are employed to respond to incidents."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "IR-04(09)-Examine",
     "objects": [
      {
       "en": "Incident response policy"
      },
      {
       "en": "procedures addressing incident handling"
      },
      {
       "en": "automated mechanisms supporting dynamic response capabilities"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "incident response plan"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "audit records"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
