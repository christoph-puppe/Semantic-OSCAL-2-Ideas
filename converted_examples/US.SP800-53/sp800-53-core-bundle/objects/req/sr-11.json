       "label": "SR-11a.",
       "children": [
        {
         "id": "sr-11_obj.a-1",
         "label": "SR-11a.[01]",
         "prose": {
          "en": "an anti-counterfeit policy is developed and implemented;"
         }
        },
        {
         "id": "sr-11_obj.a-2",
         "label": "SR-11a.[02]",
         "prose": {
          "en": "anti-counterfeit procedures are developed and implemented;"
         }
        },
        {
         "id": "sr-11_obj.a-3",
         "label": "SR-11a.[03]",
         "prose": {
          "en": "the anti-counterfeit procedures include the means to detect counterfeit components entering the system;"
