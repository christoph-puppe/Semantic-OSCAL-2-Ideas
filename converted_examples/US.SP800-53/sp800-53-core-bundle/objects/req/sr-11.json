{
 "id": "https://ns.nist.gov/sp800-53/req/SR-11",
 "version": "5.2.0",
 "label": "SR-11",
 "lifecycle": "active",
 "title": {
  "en": "Component Authenticity"
 },
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Develop and implement anti-counterfeit policy and procedures that include the means to detect and prevent counterfeit components from entering the system; and"
   },
   "parameters": [
    {
     "name": "sr-11_odp.02",
     "type": "string",
     "label": "external reporting organizations"
    },
    {
     "name": "sr-11_odp.03",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Report counterfeit system components to {param:sr-11_odp.01}."
   },
   "parameters": [
    {
     "name": "sr-11_odp.01",
     "type": "choice",
     "choices": [
      {
       "value": "source of counterfeit component"
      },
      {
       "value": "{param:sr-11_odp.02} "
      },
      {
       "value": "{param:sr-11_odp.03} "
      }
     ],
     "cardinality": "many"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Sources of counterfeit components include manufacturers, developers, vendors, and contractors. Anti-counterfeiting policies and procedures support tamper resistance and provide a level of protection against the introduction of malicious code. External reporting organizations include CISA."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "sr-11_obj",
     "label": "SR-11",
