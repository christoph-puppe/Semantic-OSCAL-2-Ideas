      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "IA-12(06)-Interview",
     "objects": [
      {
       "en": "Organizational personnel with system operations responsibilities"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      },
      {
       "en": "system/network administrators"
      },
      {
       "en": "system developers"
      },
      {
       "en": "organizational personnel with identification and authentication responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "IA-12(06)-Test",
