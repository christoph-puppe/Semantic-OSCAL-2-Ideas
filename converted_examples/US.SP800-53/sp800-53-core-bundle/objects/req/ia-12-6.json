 "version": "5.2.0",
 "label": "IA-12(6)",
 "lifecycle": "active",
 "title": "Accept Externally-proofed Identities",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Accept externally-proofed identities at {param:ia-12.06_odp}."
   },
   "parameters": [
    {
     "name": "ia-12.06_odp",
     "type": "string",
     "label": "identity assurance level"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "To limit unnecessary re-proofing of identities, particularly of non-PIV users, organizations accept proofing conducted at a commensurate level of assurance by other agencies or organizations. Proofing is consistent with organizational security policy and the identity assurance level appropriate for the system, application, or information accessed. Accepting externally-proofed identities is a fundamental component of managing federated identities across agencies and organizations."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ia-12.6_obj",
     "label": "IA-12(06)",
     "prose": {
      "en": "externally proofed identities are accepted {param:ia-12.06_odp}."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "IA-12(06)-Examine",
     "objects": [
      {
       "en": "Identification and authentication policy"
      },
