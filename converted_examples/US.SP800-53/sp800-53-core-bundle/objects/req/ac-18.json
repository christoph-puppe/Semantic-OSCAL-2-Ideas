{
 "id": "https://ns.nist.gov/sp800-53/req/AC-18",
 "version": "5.2.0",
 "label": "AC-18",
 "lifecycle": "active",
 "title": "Wireless Access",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Establish configuration requirements, connection requirements, and implementation guidance for each type of wireless access; and"
   }
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Authorize each type of wireless access to the system prior to allowing such connections."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Wireless technologies include microwave, packet radio (ultra-high frequency or very high frequency), 802.11x, and Bluetooth. Wireless networks use authentication protocols that provide authenticator protection and mutual authentication."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ac-18_obj",
     "label": "AC-18",
     "children": [
      {
       "id": "ac-18_obj.a",
       "label": "AC-18a.",
       "children": [
        {
         "id": "ac-18_obj.a-1",
         "label": "AC-18a.[01]",
         "prose": {
          "en": "configuration requirements are established for each type of wireless access;"
         }
        },
        {
         "id": "ac-18_obj.a-2",
         "label": "AC-18a.[02]",
         "prose": {
          "en": "connection requirements are established for each type of wireless access;"
         }
        },
        {
         "id": "ac-18_obj.a-3",
         "label": "AC-18a.[03]",
         "prose": {
          "en": "implementation guidance is established for each type of wireless access;"
         }
        }
       ]
      },
      {
       "id": "ac-18_obj.b",
       "label": "AC-18b.",
       "prose": {
        "en": "each type of wireless access to the system is authorized prior to allowing such connections."
       }
      }
     ]
    }
   ],
