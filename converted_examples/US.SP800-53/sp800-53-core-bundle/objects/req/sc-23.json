 "label": "SC-23",
 "lifecycle": "active",
 "title": "Session Authenticity",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Protect the authenticity of communications sessions."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Protecting session authenticity addresses communications protection at the session level, not at the packet level. Such protection establishes grounds for confidence at both ends of communications sessions in the ongoing identities of other parties and the validity of transmitted information. Authenticity protection includes protecting against \"man-in-the-middle\" attacks, session hijacking, and the insertion of false information into sessions."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
