{
 "id": "https://ns.nist.gov/sp800-53/req/SI-2.7",
 "version": "5.2.0",
 "label": "SI-2(7)",
 "lifecycle": "active",
 "title": "Root Cause Analysis",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Conduct root cause analysis to identify underlying causes of issues or failures."
   }
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Develop actions to address the root cause of the issue or failure."
   }
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Implement the actions and monitor the implementation for effectiveness."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Root cause analysis includes a wide range of approaches, tools, and techniques to systematically identify the underlying cause of issues or failures to systems and systems components (hardware, software, and firmware). Organizations consider the severity of the incident to determine what root cause analysis method is used and how quickly implementation of the remediation actions. The root cause analysis includes a timeline, missed warning signs, key decisions, gaps, mitigations, and verification of effectiveness. The actions identified to address the source of the issue are implemented and integrated into applicable organizational policy, procedures, and control implementation."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "si-2.7_obj",
     "label": "SI-02(07)",
     "prose": {
      "en": "Determine if:"
     },
     "children": [
      {
       "id": "si-2.7_obj.a",
       "label": "SI-02(07)a.",
       "prose": {
        "en": "Root cause analysis is conducted to identify underlying causes of issues or failures"
       }
      },
      {
       "id": "si-2.7_obj.b",
       "label": "SI-02(07)b.",
       "prose": {
        "en": "Actions to address the root cause of the issue of failure are developed"
       }
      },
      {
       "id": "si-2.7_obj.c",
       "label": "SI-02(07)c.",
       "children": [
        {
         "id": "si-2.7_obj.c-1",
         "prose": {
          "en": "The actions (defined in SI-02(07)b.) are implemented"
         }
        },
        {
         "id": "si-2.7_obj.c-2",
         "prose": {
          "en": "The implementation of actions is monitored for effectiveness."
         }
        }
       ]
      }
     ]
    }
   ],
   "methods": [
