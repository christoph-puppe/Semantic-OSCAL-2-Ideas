{
 "id": "https://ns.nist.gov/sp800-53/req/AC-18.1",
 "version": "5.2.0",
 "label": "AC-18(1)",
 "lifecycle": "active",
 "title": "Authentication and Encryption",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Protect wireless access to the system using authentication of {param:ac-18.01_odp} and encryption."
   },
   "parameters": [
    {
     "name": "ac-18.01_odp",
     "type": "choice",
     "choices": [
      {
       "value": "users"
      },
      {
       "value": "devices"
      }
     ],
     "cardinality": "many"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Wireless networking capabilities represent a significant potential vulnerability that can be exploited by adversaries. To protect systems with wireless access points, strong authentication of users and devices along with strong encryption can reduce susceptibility to threats by adversaries involving wireless technologies."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ac-18.1_obj",
     "label": "AC-18(01)",
     "children": [
      {
       "id": "ac-18.1_obj-1",
       "label": "AC-18(01)[01]",
       "prose": {
        "en": "wireless access to the system is protected using authentication of {param:ac-18.01_odp};"
       }
      },
      {
       "id": "ac-18.1_obj-2",
       "label": "AC-18(01)[02]",
       "prose": {
        "en": "wireless access to the system is protected using encryption."
       }
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "AC-18(01)-Examine",
     "objects": [
      {
       "en": "Access control policy"
      },
      {
       "en": "procedures addressing wireless implementation and usage (including restrictions)"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "AC-18(01)-Interview",
     "objects": [
      {
       "en": "System/network administrators"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      },
      {
       "en": "system developers"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "AC-18(01)-Test",
     "objects": [
      {
       "en": "Mechanisms implementing wireless access protections to the system"
      }
     ]
    }
   ]
  },
