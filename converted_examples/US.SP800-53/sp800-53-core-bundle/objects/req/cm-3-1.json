   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Document proposed changes to the system;"
   }
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Notify {param:cm-03.01_odp.02} of proposed changes to the system and request change approval;"
   },
   "parameters": [
    {
     "name": "cm-03.01_odp.02",
     "type": "string",
     "label": "approval authorities"
    }
   ]
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Highlight proposed changes to the system that have not been approved or disapproved within {param:cm-03.01_odp.03};"
   },
   "parameters": [
    {
     "name": "cm-03.01_odp.03",
     "type": "string",
     "label": "time period"
    }
   ]
  },
  {
   "id": "smt.d",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Prohibit changes to the system until designated approvals are received;"
   }
  },
  {
   "id": "smt.e",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Document all changes to the system; and"
   }
  },
  {
   "id": "smt.f",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Notify {param:cm-03.01_odp.04} when approved changes to the system are completed."
   },
   "parameters": [
    {
     "name": "cm-03.01_odp.04",
     "type": "string",
     "label": "personnel"
    }
   ]
  }
 ],
