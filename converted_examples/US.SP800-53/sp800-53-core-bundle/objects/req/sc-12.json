       "label": "SC-12[01]",
       "prose": {
        "en": "cryptographic keys are established when cryptography is employed within the system in accordance with {param:sc-12_odp};"
       }
      },
      {
       "id": "sc-12_obj-2",
       "label": "SC-12[02]",
       "prose": {
        "en": "cryptographic keys are managed when cryptography is employed within the system in accordance with {param:sc-12_odp}."
       }
      }
     ]
    }
