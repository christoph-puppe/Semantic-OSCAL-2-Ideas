       "id": "sc-45.1_obj.a",
       "label": "SC-45(01)(a)",
       "prose": {
        "en": "the internal system clocks are compared {param:sc-45.01_odp.01} with {param:sc-45.01_odp.02};"
       }
      },
      {
       "id": "sc-45.1_obj.b",
       "label": "SC-45(01)(b)",
       "prose": {
        "en": "the internal system clocks are synchronized with the authoritative time source when the time difference is greater than {param:sc-45.01_odp.03}."
       }
      }
     ]
    }
   ],
