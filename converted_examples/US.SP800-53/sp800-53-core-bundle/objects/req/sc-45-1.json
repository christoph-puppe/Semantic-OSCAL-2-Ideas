 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Compare the internal system clocks {param:sc-45.01_odp.01} with {param:sc-45.01_odp.02} ; and"
   },
   "parameters": [
    {
     "name": "sc-45.01_odp.01",
     "type": "string",
     "label": "frequency"
    },
    {
     "name": "sc-45.01_odp.02",
     "type": "string",
     "label": "authoritative time source"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Synchronize the internal system clocks to the authoritative time source when the time difference is greater than {param:sc-45.01_odp.03}."
   },
   "parameters": [
    {
     "name": "sc-45.01_odp.03",
     "type": "string",
     "label": "time period"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Synchronization of internal system clocks with an authoritative source provides uniformity of time stamps for systems with multiple system clocks and systems connected over a network."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "sc-45.1_obj",
