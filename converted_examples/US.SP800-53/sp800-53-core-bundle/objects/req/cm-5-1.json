 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Organizations log system accesses associated with applying configuration changes to ensure that configuration change control is implemented and to support after-the-fact actions should organizations discover any unauthorized changes."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
