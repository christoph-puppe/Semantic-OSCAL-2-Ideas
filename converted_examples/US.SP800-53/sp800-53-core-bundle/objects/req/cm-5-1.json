       "label": "CM-05(01)(a)",
       "prose": {
        "en": "access restrictions for change are enforced using {param:cm-05.01_odp};"
       }
      },
      {
       "id": "cm-5.1_obj.b",
       "label": "CM-05(01)(b)",
       "prose": {
        "en": "audit records of enforcement actions are automatically generated."
       }
