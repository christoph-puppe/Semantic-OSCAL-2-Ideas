   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Enforce access restrictions using {param:cm-05.01_odp} ; and"
   },
