 "title": "Contingency Plan Testing",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Test the contingency plan for the system {param:cp-04_odp.01} using the following tests to determine the effectiveness of the plan and the readiness to execute the plan: {param:cp-4_prm_2}."
   },
   "parameters": [
    {
     "name": "cp-04_odp.01",
     "type": "string",
     "label": "frequency"
    },
    {
     "name": "cp-4_prm_2",
     "type": "string",
     "label": "organization-defined tests"
    },
    {
     "name": "cp-04_odp.02",
     "type": "string",
     "label": "tests"
    },
    {
     "name": "cp-04_odp.03",
     "type": "string",
     "label": "tests"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Review the contingency plan test results; and"
   }
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Initiate corrective actions, if needed."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Methods for testing contingency plans to determine the effectiveness of the plans and identify potential weaknesses include checklists, walk-through and tabletop exercises, simulations (parallel or full interrupt), and comprehensive exercises. Organizations conduct testing based on the requirements in contingency plans and include a determination of the effects on organizational operations, assets, and individuals due to contingency operations. Organizations have flexibility and discretion in the breadth, depth, and timelines of corrective actions."
    }
   ]
  },
