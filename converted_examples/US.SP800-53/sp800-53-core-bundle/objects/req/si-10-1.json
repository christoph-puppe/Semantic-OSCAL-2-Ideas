 "title": "Manual Override Capability",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Provide a manual override capability for input validation of the following information inputs: {param:si-10_odp};"
   },
   "parameters": [
    {
     "name": "si-10_odp",
     "type": "string",
     "label": "information inputs"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Restrict the use of the manual override capability to only {param:si-10.01_odp} ; and"
   },
   "parameters": [
    {
     "name": "si-10.01_odp",
     "type": "string",
     "label": "authorized individuals"
    }
   ]
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Audit the use of the manual override capability."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "In certain situations, such as during events that are defined in contingency plans, a manual override capability for input validation may be needed. Manual overrides are used only in limited circumstances and with the inputs defined by the organization."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "si-10.1_obj",
     "label": "SI-10(01)",
     "children": [
      {
       "id": "si-10.1_obj.a",
       "label": "SI-10(01)(a)",
       "prose": {
        "en": "a manual override capability for the validation of {param:si-10_odp} is provided;"
       }
      },
      {
       "id": "si-10.1_obj.b",
       "label": "SI-10(01)(b)",
       "prose": {
        "en": "the use of the manual override capability is restricted to only {param:si-10.01_odp};"
       }
      },
      {
       "id": "si-10.1_obj.c",
       "label": "SI-10(01)(c)",
       "prose": {
        "en": "the use of the manual override capability is audited."
       }
      }
     ]
    }
