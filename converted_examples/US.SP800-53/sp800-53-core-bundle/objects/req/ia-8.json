{
 "id": "https://ns.nist.gov/sp800-53/req/IA-8",
 "version": "5.2.0",
 "label": "IA-8",
 "lifecycle": "active",
 "title": "Identification and Authentication (Non-organizational Users)",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Uniquely identify and authenticate non-organizational users or processes acting on behalf of non-organizational users."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Non-organizational users include system users other than organizational users explicitly covered by IA-2 . Non-organizational users are uniquely identified and authenticated for accesses other than those explicitly identified and documented in AC-14 . Identification and authentication of non-organizational users accessing federal systems may be required to protect federal, proprietary, or privacy-related information (with exceptions noted for national security systems). Organizations consider many factors—including security, privacy, scalability, and practicality—when balancing the need to ensure ease of use for access to federal information and systems with the need to protect and adequately mitigate risk."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ia-8_obj",
     "label": "IA-08",
     "prose": {
      "en": "non-organizational users or processes acting on behalf of non-organizational users are uniquely identified and authenticated."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "IA-08-Examine",
     "objects": [
      {
       "en": "Identification and authentication policy"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "privacy plan"
      },
      {
       "en": "procedures addressing user identification and authentication"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "list of system accounts"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "IA-08-Interview",
     "objects": [
      {
       "en": "Organizational personnel with system operations responsibilities"
      },
      {
       "en": "organizational personnel with information security and privacy responsibilities"
      },
      {
       "en": "system/network administrators"
      },
      {
       "en": "organizational personnel with account management responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "IA-08-Test",
     "objects": [
      {
       "en": "Mechanisms supporting and/or implementing identification and authentication capabilities"
      }
     ]
    }
   ]
  }
 },
