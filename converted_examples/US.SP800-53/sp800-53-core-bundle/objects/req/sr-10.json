{
 "id": "https://ns.nist.gov/sp800-53/req/SR-10",
 "version": "5.2.0",
 "label": "SR-10",
 "lifecycle": "active",
 "title": "Inspection of Systems or Components",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Inspect the following systems or system components {param:sr-10_odp.02} to detect tampering: {param:sr-10_odp.01}."
   },
   "parameters": [
    {
     "name": "sr-10_odp.01",
     "type": "string",
     "label": "systems or system components"
    },
    {
     "name": "sr-10_odp.02",
     "type": "choice",
     "choices": [
      {
       "value": "at random"
      },
      {
       "value": "at {param:sr-10_odp.03} "
      },
      {
       "value": "upon {param:sr-10_odp.04} "
      }
     ],
     "cardinality": "many"
    },
    {
     "name": "sr-10_odp.03",
     "type": "string",
     "label": "frequency"
    },
    {
     "name": "sr-10_odp.04",
     "type": "string",
     "label": "indications of need for inspection"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "The inspection of systems or systems components for tamper resistance and detection addresses physical and logical tampering and is applied to systems and system components removed from organization-controlled areas. Indications of a need for inspection include changes in packaging, specifications, factory location, or entity in which the part is purchased, and when individuals return from travel to high-risk locations."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "sr-10_obj",
     "label": "SR-10",
     "prose": {
      "en": "{param:sr-10_odp.01} are inspected {param:sr-10_odp.02} to detect tampering."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "SR-10-Examine",
     "objects": [
      {
       "en": "Supply chain risk management policy and procedures"
      },
      {
       "en": "supply chain risk management plan"
      },
      {
       "en": "system and services acquisition policy"
      },
      {
       "en": "records of random inspections"
      },
      {
       "en": "inspection reports/results"
      },
      {
       "en": "assessment reports/results"
      },
      {
       "en": "acquisition documentation"
      },
      {
       "en": "service level agreements"
      },
      {
       "en": "acquisition contracts for the system, system component, or system service"
      },
      {
       "en": "inter-organizational agreements and procedures"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "SR-10-Interview",
     "objects": [
      {
       "en": "Organizational personnel with system and services acquisition responsibilities"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      },
      {
       "en": "organizational personnel with supply chain risk management responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "SR-10-Test",
     "objects": [
      {
       "en": "Organizational processes for establishing inter-organizational agreements and procedures with supply chain entities"
      },
      {
       "en": "organizational processes to inspect for tampering"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
    "sr-10_odp.01": {
     "guidelines": [
      {
       "en": "systems or system components that require inspection are defined;"
      }
     ],
     "alt-identifiers": [
      "sr-10_prm_4"
     ]
    },
    "sr-10_odp.02": {
     "alt-identifiers": [
      "sr-10_prm_1"
     ]
    },
    "sr-10_odp.03": {
     "guidelines": [
      {
       "en": "frequency at which to inspect systems or system components is defined (if selected);"
      }
     ],
     "alt-identifiers": [
      "sr-10_prm_2"
     ]
    },
    "sr-10_odp.04": {
     "guidelines": [
      {
       "en": "indications of the need for an inspection of systems or system components are defined (if selected);"
      }
     ],
     "alt-identifiers": [
      "sr-10_prm_3"
     ]
    }
   }
  },
  "https://ns.nist.gov/sp800-53/facet/rmf@1": {
   "contributes-to-assurance": true
  }
 },
