{
 "id": "https://ns.nist.gov/sp800-53/req/AC-6",
 "version": "5.2.0",
 "label": "AC-6",
 "lifecycle": "active",
 "title": {
  "en": "Least Privilege"
 },
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Employ the principle of least privilege, allowing only authorized accesses for users (or processes acting on behalf of users) that are necessary to accomplish assigned organizational tasks."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Organizations employ least privilege for specific duties and systems. The principle of least privilege is also applied to system processes, ensuring that the processes have access to systems and operate at privilege levels no higher than necessary to accomplish organizational missions or business functions. Organizations consider the creation of additional processes, roles, and accounts as necessary to achieve least privilege. Organizations apply least privilege to the development, implementation, and operation of organizational systems."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ac-6_obj",
     "label": "AC-06",
     "prose": {
      "en": "the principle of least privilege is employed, allowing only authorized accesses for users (or processes acting on behalf of users) that are necessary to accomplish assigned organizational tasks."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "AC-06-Examine",
     "objects": [
      {
       "en": "Access control policy"
      },
      {
       "en": "procedures addressing least privilege"
      },
      {
       "en": "list of assigned access authorizations (user privileges)"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "AC-06-Interview",
     "objects": [
      {
       "en": "Organizational personnel with responsibilities for defining least privileges necessary to accomplish specified tasks"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      },
      {
       "en": "system/network administrators"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "AC-06-Test",
     "objects": [
      {
       "en": "Mechanisms implementing least privilege functions"
      }
     ]
    }
   ]
  }
 },
