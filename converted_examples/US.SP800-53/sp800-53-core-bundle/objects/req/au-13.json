{
 "id": "https://ns.nist.gov/sp800-53/req/AU-13",
 "version": "5.2.0",
 "label": "AU-13",
 "lifecycle": "active",
 "title": {
  "en": "Monitoring for Information Disclosure"
 },
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Monitor {param:au-13_odp.01} {param:au-13_odp.02} for evidence of unauthorized disclosure of organizational information; and"
   },
   "parameters": [
    {
     "name": "au-13_odp.01",
     "type": "string",
     "label": "open-source information and/or information sites"
    },
    {
     "name": "au-13_odp.02",
     "type": "string",
     "label": "frequency"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "If an information disclosure is discovered:"
   }
  },
  {
   "id": "smt.b.1",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Notify {param:au-13_odp.03} ; and"
   },
   "parameters": [
    {
     "name": "au-13_odp.03",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  },
  {
   "id": "smt.b.2",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Take the following additional actions: {param:au-13_odp.04}."
   },
   "parameters": [
    {
     "name": "au-13_odp.04",
     "type": "string",
     "label": "additional actions"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Unauthorized disclosure of information is a form of data leakage. Open-source information includes social networking sites and code-sharing platforms and repositories. Examples of organizational information include personally identifiable information retained by the organization or proprietary information generated by the organization."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "au-13_obj",
     "label": "AU-13",
     "children": [
      {
       "id": "au-13_obj.a",
       "label": "AU-13a.",
       "prose": {
        "en": "{param:au-13_odp.01} is/are monitored {param:au-13_odp.02} for evidence of unauthorized disclosure of organizational information;"
       }
      },
      {
       "id": "au-13_obj.b",
       "label": "AU-13b.",
       "children": [
        {
         "id": "au-13_obj.b.1",
         "label": "AU-13b.01",
         "prose": {
          "en": "{param:au-13_odp.03} are notified if an information disclosure is discovered;"
         }
        },
        {
         "id": "au-13_obj.b.2",
         "label": "AU-13b.02",
         "prose": {
          "en": "{param:au-13_odp.04} are taken if an information disclosure is discovered."
         }
        }
       ]
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "AU-13-Examine",
     "objects": [
      {
       "en": "Audit and accountability policy"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "privacy plan"
      },
      {
       "en": "procedures addressing information disclosure monitoring"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "monitoring records"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "AU-13-Interview",
     "objects": [
      {
       "en": "Organizational personnel with responsibilities for monitoring open-source information and/or information sites"
      },
      {
       "en": "organizational personnel with security and privacy responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "AU-13-Test",
     "objects": [
      {
       "en": "Mechanisms implementing monitoring for information disclosure"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
    "au-13_odp.01": {
     "guidelines": [
      {
       "en": "open-source information and/or information sites to be monitored for evidence of unauthorized disclosure of organizational information is/are defined;"
      }
     ],
     "alt-identifiers": [
      "au-13_prm_1"
     ]
    },
    "au-13_odp.02": {
     "guidelines": [
      {
       "en": "the frequency with which open-source information and/or information sites are monitored for evidence of unauthorized disclosure of organizational information is defined;"
      }
     ],
     "alt-identifiers": [
      "au-13_prm_2"
     ]
    },
    "au-13_odp.03": {
     "guidelines": [
      {
       "en": "personnel or roles to be notified if an information disclosure is discovered is/are defined;"
      }
     ],
     "alt-identifiers": [
      "au-13_prm_3"
     ]
    },
    "au-13_odp.04": {
     "guidelines": [
      {
       "en": "additional actions to be taken if an information disclosure is discovered are defined;"
      }
     ],
     "alt-identifiers": [
      "au-13_prm_4"
     ]
    }
   }
  },
  "https://ns.nist.gov/sp800-53/facet/rmf@1": {
   "contributes-to-assurance": true
  }
 },
