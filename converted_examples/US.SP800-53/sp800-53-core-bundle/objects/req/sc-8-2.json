 "version": "5.2.0",
 "label": "SC-8(2)",
 "lifecycle": "active",
 "title": {
  "en": "Pre- and Post-transmission Handling"
 },
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Maintain the {param:sc-08.02_odp} of information during preparation for transmission and during reception."
   },
   "parameters": [
    {
     "name": "sc-08.02_odp",
     "type": "choice",
     "choices": [
      {
       "value": "confidentiality"
      },
      {
       "value": "integrity"
      }
     ],
     "cardinality": "many"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Information can be unintentionally or maliciously disclosed or modified during preparation for transmission or during reception, including during aggregation, at protocol transformation points, and during packing and unpacking. Such unauthorized disclosures or modifications compromise the confidentiality or integrity of the information."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
