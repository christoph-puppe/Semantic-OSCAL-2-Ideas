       "prose": {
        "en": "information {param:sc-08.02_odp} is/are maintained during preparation for transmission;"
       }
      },
      {
       "id": "sc-8.2_obj-2",
       "label": "SC-08(02)[02]",
       "prose": {
        "en": "information {param:sc-08.02_odp} is/are maintained during reception."
       }
      }
     ]
    }
   ],
   "methods": [
