{
 "id": "https://ns.nist.gov/sp800-53/req/SC-34.2",
 "version": "5.2.0",
 "label": "SC-34(2)",
 "lifecycle": "active",
 "title": {
  "en": "Integrity Protection on Read-only Media"
 },
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Protect the integrity of information prior to storage on read-only media and control the media after such information has been recorded onto the media."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Controls prevent the substitution of media into systems or the reprogramming of programmable read-only media prior to installation into the systems. Integrity protection controls include a combination of prevention, detection, and response."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "sc-34.2_obj",
     "label": "SC-34(02)",
     "children": [
      {
       "id": "sc-34.2_obj-1",
       "label": "SC-34(02)[01]",
       "prose": {
        "en": "the integrity of information is protected prior to storage on read-only media;"
       }
      },
      {
       "id": "sc-34.2_obj-2",
       "label": "SC-34(02)[02]",
       "prose": {
        "en": "the media is controlled after such information has been recorded onto the media;"
       }
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "SC-34(02)-Examine",
     "objects": [
      {
       "en": "System and communications protection policy"
      },
      {
       "en": "procedures addressing non-modifiable executable programs"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system architecture"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "SC-34(02)-Interview",
     "objects": [
      {
       "en": "System/network administrators"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      },
      {
       "en": "organizational personnel installing, configuring, and/or maintaining the system"
      },
      {
       "en": "system developers/integrators"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "SC-34(02)-Test",
     "objects": [
      {
       "en": "Mechanisms supporting and/or implementing the capability to protect information integrity on read-only media prior to storage and after information has been recorded onto the media"
      }
     ]
    }
   ]
  },
