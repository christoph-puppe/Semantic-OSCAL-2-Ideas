 "title": {
  "en": "Review System Changes"
 },
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Review changes to the system {param:cm-03.07_odp.01} or when {param:cm-03.07_odp.02} to determine whether unauthorized changes have occurred."
   },
   "parameters": [
    {
     "name": "cm-03.07_odp.01",
     "type": "string",
     "label": "frequency"
    },
    {
     "name": "cm-03.07_odp.02",
     "type": "string",
     "label": "circumstances"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Indications that warrant a review of changes to the system and the specific circumstances justifying such reviews may be obtained from activities carried out by organizations during the configuration change process or continuous monitoring process."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "cm-3.7_obj",
     "label": "CM-03(07)",
     "prose": {
      "en": "changes to the system are reviewed {param:cm-03.07_odp.01} or when {param:cm-03.07_odp.02} to determine whether unauthorized changes have occurred."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "CM-03(07)-Examine",
     "objects": [
      {
       "en": "Configuration management policy"
      },
      {
       "en": "procedures addressing system configuration change control"
      },
      {
       "en": "configuration management plan"
      },
      {
       "en": "change control records"
      },
      {
       "en": "system architecture and configuration documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system component inventory"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "CM-03(07)-Interview",
     "objects": [
      {
       "en": "Organizational personnel with configuration change control responsibilities"
      },
      {
       "en": "organizational personnel with security responsibilities"
      },
      {
       "en": "system/network administrators"
      },
      {
       "en": "members of change control board or similar"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "CM-03(07)-Test",
     "objects": [
      {
       "en": "Organizational processes for configuration change control"
      },
      {
       "en": "mechanisms implementing audit records for changes"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
