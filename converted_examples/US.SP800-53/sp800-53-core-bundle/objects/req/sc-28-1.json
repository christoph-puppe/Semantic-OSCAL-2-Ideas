       "id": "sc-28.1_obj-1",
       "label": "SC-28(01)[01]",
       "prose": {
        "en": "cryptographic mechanisms are implemented to prevent unauthorized disclosure of {param:sc-28.01_odp.01} at rest on {param:sc-28.01_odp.02};"
       }
      },
      {
       "id": "sc-28.1_obj-2",
       "label": "SC-28(01)[02]",
       "prose": {
        "en": "cryptographic mechanisms are implemented to prevent unauthorized modification of {param:sc-28.01_odp.01} at rest on {param:sc-28.01_odp.02}."
       }
      }
     ]
    }
   ],
