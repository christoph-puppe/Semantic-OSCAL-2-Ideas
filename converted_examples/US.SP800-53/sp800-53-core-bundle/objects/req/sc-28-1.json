 "label": "SC-28(1)",
 "lifecycle": "active",
 "title": "Cryptographic Protection",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Implement cryptographic mechanisms to prevent unauthorized disclosure and modification of the following information at rest on {param:sc-28.01_odp.02}: {param:sc-28.01_odp.01}."
   },
   "parameters": [
    {
     "name": "sc-28.01_odp.01",
     "type": "string",
     "label": "information"
    },
    {
     "name": "sc-28.01_odp.02",
     "type": "string",
     "label": "system components or media"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "The selection of cryptographic mechanisms is based on the need to protect the confidentiality and integrity of organizational information. The strength of mechanism is commensurate with the security category or classification of the information. Organizations have the flexibility to encrypt information on system components or media or encrypt data structures, including files, records, or fields."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
