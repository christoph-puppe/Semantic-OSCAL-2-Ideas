   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Implement the following host-based monitoring mechanisms at {param:si-04.23_odp.02}: {param:si-04.23_odp.01}."
   },
   "parameters": [
    {
     "name": "si-04.23_odp.01",
     "type": "string",
     "label": "host-based monitoring mechanisms"
    },
    {
     "name": "si-04.23_odp.02",
     "type": "string",
     "label": "system components"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Host-based monitoring collects information about the host (or system in which it resides). System components in which host-based monitoring can be implemented include servers, notebook computers, and mobile devices. Organizations may consider employing host-based monitoring mechanisms from multiple product developers or vendors."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
