     "id": "si-4.23_obj",
     "label": "SI-04(23)",
     "prose": {
      "en": "{param:si-04.23_odp.01} are implemented on {param:si-04.23_odp.02}."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "SI-04(23)-Examine",
     "objects": [
