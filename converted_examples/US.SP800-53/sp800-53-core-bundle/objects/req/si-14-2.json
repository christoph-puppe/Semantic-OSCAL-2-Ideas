     "guidelines": [
      {
       "en": "the information to be refreshed is defined (if selected);"
      }
     ],
     "alt-identifiers": [
      "si-14.2_prm_2"
     ]
    },
    "si-14.02_odp.03": {
     "guidelines": [
      {
       "en": "the frequency at which to refresh information is defined (if selected);"
      }
     ],
     "alt-identifiers": [
      "si-14.2_prm_3"
     ]
    },
    "si-14.02_odp.04": {
     "guidelines": [
      {
