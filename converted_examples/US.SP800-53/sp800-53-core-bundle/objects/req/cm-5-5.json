{
 "id": "https://ns.nist.gov/sp800-53/req/CM-5.5",
 "version": "5.2.0",
 "label": "CM-5(5)",
 "lifecycle": "active",
 "title": {
  "en": "Privilege Limitation for Production and Operation"
 },
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Limit privileges to change system components and system-related information within a production or operational environment; and"
   },
   "parameters": [
    {
     "name": "cm-05.05_odp.01",
     "type": "string",
     "label": "frequency"
    },
    {
     "name": "cm-05.05_odp.02",
     "type": "string",
     "label": "frequency"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Review and reevaluate privileges {param:cm-5.5_prm_1}."
   },
   "parameters": [
    {
     "name": "cm-5.5_prm_1",
     "type": "string",
     "label": "organization-defined frequency"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "In many organizations, systems support multiple mission and business functions. Limiting privileges to change system components with respect to operational systems is necessary because changes to a system component may have far-reaching effects on mission and business processes supported by the system. The relationships between systems and mission/business processes are, in some cases, unknown to developers. System-related information includes operational procedures."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "cm-5.5_obj",
     "label": "CM-05(05)",
     "children": [
      {
       "id": "cm-5.5_obj.a",
       "label": "CM-05(05)(a)",
       "children": [
        {
         "id": "cm-5.5_obj.a-1",
         "label": "CM-05(05)(a)[01]",
         "prose": {
          "en": "privileges to change system components within a production or operational environment are limited;"
         }
        },
        {
         "id": "cm-5.5_obj.a-2",
         "label": "CM-05(05)(a)[02]",
         "prose": {
          "en": "privileges to change system-related information within a production or operational environment are limited;"
         }
        }
       ]
      },
      {
       "id": "cm-5.5_obj.b",
       "label": "CM-05(05)(b)",
       "children": [
        {
         "id": "cm-5.5_obj.b-1",
         "label": "CM-05(05)(b)[01]",
         "prose": {
          "en": "privileges are reviewed {param:cm-05.05_odp.01};"
         }
        },
        {
         "id": "cm-5.5_obj.b-2",
         "label": "CM-05(05)(b)[02]",
         "prose": {
          "en": "privileges are reevaluated {param:cm-05.05_odp.02}."
         }
        }
       ]
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "CM-05(05)-Examine",
     "objects": [
      {
       "en": "Configuration management policy"
      },
      {
       "en": "procedures addressing access restrictions for changes to the system"
      },
      {
       "en": "configuration management plan"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system architecture and configuration documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "user privilege reviews"
      },
      {
       "en": "user privilege recertifications"
      },
      {
       "en": "system component inventory"
      },
      {
       "en": "change control records"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "CM-05(05)-Interview",
     "objects": [
      {
       "en": "Organizational personnel with information security responsibilities"
      },
      {
       "en": "system/network administrators"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "CM-05(05)-Test",
     "objects": [
      {
       "en": "Organizational processes for managing access restrictions to change"
      },
      {
       "en": "mechanisms supporting and/or implementing access restrictions for change"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
