     "name": "si-06_odp.01",
     "type": "string",
     "label": "security functions"
    },
    {
     "name": "si-06_odp.02",
     "type": "string",
     "label": "privacy functions"
    },
    {
     "name": "si-06_odp.04",
     "type": "string",
     "label": "system transitional states"
    },
    {
     "name": "si-06_odp.05",
     "type": "string",
     "label": "frequency"
    },
    {
     "name": "si-06_odp.08",
     "type": "string",
     "label": "alternative action(s)"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Perform the verification of the functions specified in SI-6a {param:si-06_odp.03};"
   },
   "parameters": [
    {
     "name": "si-06_odp.03",
     "type": "choice",
     "choices": [
      {
       "value": "{param:si-06_odp.04} "
      },
      {
       "value": "upon command by user with appropriate privilege"
      },
      {
       "value": "{param:si-06_odp.05} "
      }
     ],
     "cardinality": "many"
    }
   ]
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Alert {param:si-06_odp.06} to failed security and privacy verification tests; and"
   },
   "parameters": [
    {
     "name": "si-06_odp.06",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  },
  {
   "id": "smt.d",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "{param:si-06_odp.07} when anomalies are discovered."
   },
   "parameters": [
    {
     "name": "si-06_odp.07",
     "type": "choice",
     "choices": [
      {
       "value": "shut the system down"
      },
      {
       "value": "restart the system"
      },
      {
       "value": "{param:si-06_odp.08} "
      }
     ],
     "cardinality": "many"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Transitional states for systems include system startup, restart, shutdown, and abort. System notifications include hardware indicator lights, electronic alerts to system administrators, and messages to local computer consoles. In contrast to security function verification, privacy function verification ensures that privacy functions operate as expected and are approved by the senior agency official for privacy or that privacy attributes are applied or used as expected."
    }
   ]
  },
