       "id": "cm-7.4_obj.a",
       "label": "CM-07(04)(a)",
       "prose": {
        "en": "{param:cm-07.04_odp.01} are identified;"
       }
      },
      {
       "id": "cm-7.4_obj.b",
       "label": "CM-07(04)(b)",
       "prose": {
        "en": "an allow-all, deny-by-exception policy is employed to prohibit the execution of unauthorized software programs on the system;"
       }
      },
      {
       "id": "cm-7.4_obj.c",
       "label": "CM-07(04)(c)",
       "prose": {
        "en": "the list of unauthorized software programs is reviewed and updated {param:cm-07.04_odp.02}."
       }
      }
     ]
    }
