 "label": "CM-7(4)",
 "lifecycle": "active",
 "title": "Unauthorized Software — Deny-by-exception",
 "statements": [
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Identify {param:cm-07.04_odp.01};"
   },
   "parameters": [
    {
     "name": "cm-07.04_odp.01",
     "type": "string",
     "label": "software programs"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Employ an allow-all, deny-by-exception policy to prohibit the execution of unauthorized software programs on the system; and"
   }
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Review and update the list of unauthorized software programs {param:cm-07.04_odp.02}."
   },
   "parameters": [
    {
     "name": "cm-07.04_odp.02",
     "type": "string",
     "label": "frequency"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Unauthorized software programs can be limited to specific versions or from a specific source. The concept of prohibiting the execution of unauthorized software may also be applied to user actions, system ports and protocols, IP addresses/ranges, websites, and MAC addresses."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
