      },
      {
       "en": "records of actions taken in response to reviews/analyses of audit records"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "AU-06-Interview",
     "objects": [
      {
       "en": "Organizational personnel with audit review, analysis, and reporting responsibilities"
      },
      {
       "en": "organizational personnel with information security and privacy responsibilities"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
