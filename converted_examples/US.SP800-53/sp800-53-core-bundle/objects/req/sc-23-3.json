{
 "id": "https://ns.nist.gov/sp800-53/req/SC-23.3",
 "version": "5.2.0",
 "label": "SC-23(3)",
 "lifecycle": "active",
 "title": {
  "en": "Unique System-generated Session Identifiers"
 },
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Generate a unique session identifier for each session with {param:sc-23.03_odp} and recognize only session identifiers that are system-generated."
   },
   "parameters": [
    {
     "name": "sc-23.03_odp",
     "type": "string",
     "label": "randomness requirements"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Generating unique session identifiers curtails the ability of adversaries to reuse previously valid session IDs. Employing the concept of randomness in the generation of unique session identifiers protects against brute-force attacks to determine future session identifiers."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "sc-23.3_obj",
     "label": "SC-23(03)",
     "children": [
      {
       "id": "sc-23.3_obj-1",
       "label": "SC-23(03)[01]",
       "prose": {
        "en": "a unique session identifier is generated for each session with {param:sc-23.03_odp};"
       }
      },
      {
       "id": "sc-23.3_obj-2",
       "label": "SC-23(03)[02]",
       "prose": {
        "en": "only system-generated session identifiers are recognized."
       }
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "SC-23(03)-Examine",
     "objects": [
      {
       "en": "System and communications protection policy"
      },
      {
       "en": "procedures addressing session authenticity"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "SC-23(03)-Interview",
     "objects": [
      {
       "en": "System/network administrators"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "SC-23(03)-Test",
     "objects": [
      {
       "en": "Mechanisms supporting, implementing, generating, and monitoring unique session identifiers"
      },
      {
       "en": "mechanisms supporting and/or implementing randomness requirements"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
    "sc-23.03_odp": {
     "guidelines": [
      {
       "en": "randomness requirements for generating a unique session identifier for each session are defined;"
      }
     ],
     "alt-identifiers": [
      "sc-23.3_prm_1"
     ]
    }
   }
  }
 },
