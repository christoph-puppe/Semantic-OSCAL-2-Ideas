 "version": "5.2.0",
 "label": "IR-5",
 "lifecycle": "active",
 "title": "Incident Monitoring",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Track and document incidents."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Documenting incidents includes maintaining records about each incident, the status of the incident, and other pertinent information necessary for forensics as well as evaluating incident details, trends, and handling. Incident information can be obtained from a variety of sources, including network monitoring, incident reports, incident response teams, user complaints, supply chain partners, audit monitoring, physical access monitoring, and user and administrator reports. IR-4 provides information on the types of incidents that are appropriate for monitoring."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ir-5_obj",
     "label": "IR-05",
     "children": [
      {
       "id": "ir-5_obj-1",
       "label": "IR-05[01]",
       "prose": {
        "en": "incidents are tracked;"
       }
      },
      {
       "id": "ir-5_obj-2",
       "label": "IR-05[02]",
       "prose": {
        "en": "incidents are documented."
       }
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "IR-05-Examine",
     "objects": [
      {
       "en": "Incident response policy"
      },
      {
       "en": "procedures addressing incident monitoring"
      },
      {
       "en": "incident response records and documentation"
      },
      {
       "en": "incident response plan"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "privacy plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "IR-05-Interview",
     "objects": [
