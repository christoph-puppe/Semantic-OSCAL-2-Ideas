       "en": "Organizational personnel with incident monitoring responsibilities"
      },
      {
       "en": "organizational personnel with information security and privacy responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "IR-05-Test",
     "objects": [
      {
       "en": "Incident monitoring capability for the organization"
      },
      {
       "en": "mechanisms supporting and/or implementing the tracking and documenting of system security incidents"
      }
     ]
    }
   ]
  },
