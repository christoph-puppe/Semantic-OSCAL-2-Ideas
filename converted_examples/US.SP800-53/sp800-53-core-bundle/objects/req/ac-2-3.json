{
 "id": "https://ns.nist.gov/sp800-53/req/AC-2.3",
 "version": "5.2.0",
 "label": "AC-2(3)",
 "lifecycle": "active",
 "title": "Disable Accounts",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Disable accounts within {param:ac-02.03_odp.01} when the accounts:"
   },
   "parameters": [
    {
     "name": "ac-02.03_odp.01",
     "type": "string",
     "label": "time period"
    }
   ]
  },
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Have expired;"
   }
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Are no longer associated with a user or individual;"
   }
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Are in violation of organizational policy; or"
   }
  },
  {
   "id": "smt.d",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Have been inactive for {param:ac-02.03_odp.02}."
   },
   "parameters": [
    {
     "name": "ac-02.03_odp.02",
     "type": "string",
     "label": "time period"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Disabling expired, inactive, or otherwise anomalous accounts supports the concepts of least privilege and least functionality which reduce the attack surface of the system."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ac-2.3_obj",
     "label": "AC-02(03)",
     "children": [
      {
       "id": "ac-2.3_obj.a",
       "label": "AC-02(03)(a)",
       "prose": {
        "en": "accounts are disabled within {param:ac-02.03_odp.01} when the accounts have expired;"
       }
      },
      {
       "id": "ac-2.3_obj.b",
       "label": "AC-02(03)(b)",
       "prose": {
        "en": "accounts are disabled within {param:ac-02.03_odp.01} when the accounts are no longer associated with a user or individual;"
       }
      },
      {
       "id": "ac-2.3_obj.c",
       "label": "AC-02(03)(c)",
       "prose": {
        "en": "accounts are disabled within {param:ac-02.03_odp.01} when the accounts are in violation of organizational policy;"
       }
      },
      {
       "id": "ac-2.3_obj.d",
       "label": "AC-02(03)(d)",
       "prose": {
        "en": "accounts are disabled within {param:ac-02.03_odp.01} when the accounts have been inactive for {param:ac-02.03_odp.02}."
       }
      }
     ]
    }
   ],
   "methods": [
