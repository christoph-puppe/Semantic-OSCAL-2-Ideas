{
 "id": "https://ns.nist.gov/sp800-53/req/SR-9",
 "version": "5.2.0",
 "label": "SR-9",
 "lifecycle": "active",
 "title": "Tamper Resistance and Detection",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Implement a tamper protection program for the system, system component, or system service."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Anti-tamper technologies, tools, and techniques provide a level of protection for systems, system components, and services against many threats, including reverse engineering, modification, and substitution. Strong identification combined with tamper resistance and/or tamper detection is essential to protecting systems and components during distribution and when in use."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "sr-9_obj",
     "label": "SR-09",
     "prose": {
      "en": "a tamper protection program is implemented for the system, system component, or system service."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "SR-09-Examine",
     "objects": [
      {
       "en": "Supply chain risk management policy and procedures"
      },
      {
       "en": "supply chain risk management plan"
      },
      {
       "en": "system and services acquisition policy"
      },
      {
       "en": "procedures addressing supply chain protection"
      },
      {
       "en": "procedures addressing tamper resistance and detection"
      },
      {
       "en": "tamper protection program documentation"
      },
      {
       "en": "tamper protection tools and techniques documentation"
      },
      {
       "en": "tamper resistance and detection tools and techniques documentation"
      },
      {
       "en": "acquisition documentation"
      },
      {
       "en": "service level agreements"
      },
      {
       "en": "acquisition contracts for the system, system component, or system service"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "SR-09-Interview",
     "objects": [
      {
       "en": "Organizational personnel with tamper protection program responsibilities"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      },
      {
       "en": "organizational personnel with supply chain risk management responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "SR-09-Test",
     "objects": [
      {
       "en": "Organizational processes for the implementation of the tamper protection program"
      },
      {
       "en": "mechanisms supporting and/or implementing the tamper protection program"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/rmf@1": {
   "contributes-to-assurance": true
  }
 },
