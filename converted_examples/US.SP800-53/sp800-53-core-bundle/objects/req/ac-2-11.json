     "label": "system accounts"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Specifying and enforcing usage conditions helps to enforce the principle of least privilege, increase user accountability, and enable effective account monitoring. Account monitoring includes alerts generated if the account is used in violation of organizational parameters. Organizations can describe specific conditions or circumstances under which system accounts can be used, such as by restricting usage to certain days of the week, time of day, or specific durations of time."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ac-2.11_obj",
     "label": "AC-02(11)",
     "prose": {
      "en": "{param:ac-02.11_odp.01} for {param:ac-02.11_odp.02} are enforced."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "AC-02(11)-Examine",
     "objects": [
      {
       "en": "Access control policy"
      },
      {
       "en": "procedures addressing account management"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system-generated list of system accounts and associated assignments of usage circumstances and/or usage conditions"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
