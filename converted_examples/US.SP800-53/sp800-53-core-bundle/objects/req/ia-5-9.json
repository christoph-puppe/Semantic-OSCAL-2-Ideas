   "prose": {
    "en": "Use the following external organizations to federate credentials: {param:ia-05.09_odp}."
   },
   "parameters": [
    {
     "name": "ia-05.09_odp",
     "type": "string",
     "label": "external organizations"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Federation provides organizations with the capability to authenticate individuals and devices when conducting cross-organization activities involving the processing, storage, or transmission of information. Using a specific list of approved external organizations for authentication helps to ensure that those organizations are vetted and trusted."
    }
   ]
  },
