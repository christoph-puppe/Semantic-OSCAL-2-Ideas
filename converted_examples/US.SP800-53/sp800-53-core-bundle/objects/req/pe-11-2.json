{
 "id": "https://ns.nist.gov/sp800-53/req/PE-11.2",
 "version": "5.2.0",
 "label": "PE-11(2)",
 "lifecycle": "active",
 "title": "Alternate Power Supply — Self-contained",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Provide an alternate power supply for the system that is activated {param:pe-11.02_odp.01} and that is:"
   },
   "parameters": [
    {
     "name": "pe-11.02_odp.01",
     "type": "choice",
     "choices": [
      {
       "value": "manually"
      },
      {
       "value": "automatically"
      }
     ]
    }
   ]
  },
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Self-contained;"
   }
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Not reliant on external power generation; and"
   }
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Capable of maintaining {param:pe-11.02_odp.02} in the event of an extended loss of the primary power source."
   },
   "parameters": [
    {
     "name": "pe-11.02_odp.02",
     "type": "choice",
     "choices": [
      {
       "value": "minimally required operational capability"
      },
      {
       "value": "full operational capability"
      }
     ]
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "The provision of a long-term, self-contained power supply can be satisfied by using one or more generators with sufficient capacity to meet the needs of the organization."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "pe-11.2_obj",
     "label": "PE-11(02)",
     "prose": {
      "en": "an alternate power supply provided for the system is activated {param:pe-11.02_odp.01};"
     },
     "children": [
      {
       "id": "pe-11.2_obj.a",
       "label": "PE-11(02)(a)",
       "prose": {
        "en": "the alternate power supply provided for the system is self-contained;"
       }
      },
      {
       "id": "pe-11.2_obj.b",
       "label": "PE-11(02)(b)",
       "prose": {
        "en": "the alternate power supply provided for the system is not reliant on external power generation;"
       }
      },
      {
       "id": "pe-11.2_obj.c",
       "label": "PE-11(02)(c)",
       "prose": {
        "en": "the alternate power supply provided for the system is capable of maintaining {param:pe-11.02_odp.02} in the event of an extended loss of the primary power source."
       }
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "PE-11(02)-Examine",
     "objects": [
      {
