      },
      {
       "en": "alternate power supply test records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "PE-11(02)-Interview",
     "objects": [
      {
       "en": "Organizational personnel with the responsibility for emergency power and/or planning"
      },
      {
       "en": "organizational personnel with information security responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "PE-11(02)-Test",
     "objects": [
      {
       "en": "Mechanisms supporting and/or implementing an alternate power supply"
      },
      {
       "en": "the alternate power supply"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/odp@1": {
   "params": {
