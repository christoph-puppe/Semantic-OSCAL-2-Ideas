 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "The automatic initiation of session audits at startup helps to ensure that the information being captured on selected individuals is complete and not subject to compromise through tampering by malicious threat actors."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "au-14.1_obj",
     "label": "AU-14(01)",
     "prose": {
      "en": "session audits are initiated automatically at system start-up."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "AU-14(01)-Examine",
     "objects": [
      {
       "en": "Audit and accountability policy"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "privacy plan"
      },
      {
       "en": "procedures addressing user session auditing"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "AU-14(01)-Interview",
