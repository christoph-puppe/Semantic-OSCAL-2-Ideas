      },
      {
       "en": "system/network administrators"
      },
      {
       "en": "system developers"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "AU-14(01)-Test",
     "objects": [
      {
       "en": "Mechanisms implementing user session auditing capability"
      }
     ]
    }
   ]
  },
