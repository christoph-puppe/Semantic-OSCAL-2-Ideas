{
 "id": "https://ns.nist.gov/sp800-53/req/AC-3",
 "version": "5.2.0",
 "label": "AC-3",
 "lifecycle": "active",
 "title": "Access Enforcement",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Enforce approved authorizations for logical access to information and system resources in accordance with applicable access control policies."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Access control policies control access between active entities or subjects (i.e., users or processes acting on behalf of users) and passive entities or objects (i.e., devices, files, records, domains) in organizational systems. In addition to enforcing authorized access at the system level and recognizing that systems can host many applications and services in support of mission and business functions, access enforcement mechanisms can also be employed at the application and service level to provide increased information security and privacy. In contrast to logical access controls that are implemented within the system, physical access controls are addressed by the controls in the Physical and Environmental Protection ( PE ) family."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ac-3_obj",
     "label": "AC-03",
     "prose": {
      "en": "approved authorizations for logical access to information and system resources are enforced in accordance with applicable access control policies."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "AC-03-Examine",
     "objects": [
      {
       "en": "Access control policy"
      },
      {
       "en": "procedures addressing access enforcement"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "list of approved authorizations (user privileges)"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "privacy plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "AC-03-Interview",
     "objects": [
      {
       "en": "Organizational personnel with access enforcement responsibilities"
      },
      {
       "en": "system/network administrators"
      },
      {
       "en": "organizational personnel with information security and privacy responsibilities"
      },
      {
       "en": "system developers"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "AC-03-Test",
     "objects": [
      {
       "en": "Mechanisms implementing access control policy"
      }
     ]
    }
   ]
  }
 },
