      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "logical access credentials"
      },
      {
       "en": "physical access credentials"
      },
      {
       "en": "logical access authorization records"
      },
      {
       "en": "physical access authorization records"
      },
      {
