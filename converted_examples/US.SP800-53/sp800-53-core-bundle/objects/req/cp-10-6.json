 "lifecycle": "active",
 "title": {
  "en": "Component Protection"
 },
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Protect system components used for recovery and reconstitution."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Protection of system recovery and reconstitution components (i.e., hardware, firmware, and software) includes physical and technical controls. Backup and restoration components used for recovery and reconstitution include router tables, compilers, and other system software."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "cp-10.6_obj",
     "label": "CP-10(06)",
     "prose": {
      "en": "system components used for recovery and reconstitution are protected."
     }
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "CP-10(06)-Examine",
     "objects": [
      {
       "en": "Contingency planning policy"
      },
      {
