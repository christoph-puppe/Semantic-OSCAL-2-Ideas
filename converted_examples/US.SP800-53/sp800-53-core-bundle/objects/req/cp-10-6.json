      },
      {
       "en": "organizational personnel with information security responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "CP-10(06)-Test",
     "objects": [
      {
       "en": "Organizational processes for protecting backup and restoration of hardware, firmware, and software"
      },
      {
       "en": "mechanisms supporting and/or implementing protection of backups and restoration of hardware, firmware, and software"
      }
     ]
    }
   ]
  }
 },
