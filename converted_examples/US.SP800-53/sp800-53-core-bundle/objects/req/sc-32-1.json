  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Privileged functions that operate in a single physical domain may represent a single point of failure if that domain becomes compromised or experiences a denial of service."
    }
   ]
  },
