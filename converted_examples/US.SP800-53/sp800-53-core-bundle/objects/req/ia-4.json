{
 "id": "https://ns.nist.gov/sp800-53/req/IA-4",
 "version": "5.2.0",
 "label": "IA-4",
 "lifecycle": "active",
 "title": "Identifier Management",
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Manage system identifiers by:"
   }
  },
  {
   "id": "smt.a",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Receiving authorization from {param:ia-04_odp.01} to assign an individual, group, role, service, or device identifier;"
   },
   "parameters": [
    {
     "name": "ia-04_odp.01",
     "type": "string",
     "label": "personnel or roles"
    }
   ]
  },
  {
   "id": "smt.b",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Selecting an identifier that identifies an individual, group, role, service, or device;"
   }
  },
  {
   "id": "smt.c",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Assigning the identifier to the intended individual, group, role, service, or device; and"
   }
  },
  {
   "id": "smt.d",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization"
   ],
   "prose": {
    "en": "Preventing reuse of identifiers for {param:ia-04_odp.02}."
   },
   "parameters": [
    {
     "name": "ia-04_odp.02",
     "type": "string",
     "label": "time period"
    }
   ]
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Common device identifiers include Media Access Control (MAC) addresses, Internet Protocol (IP) addresses, or device-unique token identifiers. The management of individual identifiers is not applicable to shared system accounts. Typically, individual identifiers are the usernames of the system accounts assigned to those individuals. In such instances, the account management activities of AC-2 use account names provided by IA-4 . Identifier management also addresses individual identifiers not necessarily associated with system accounts. Preventing the reuse of identifiers implies preventing the assignment of previously used individual, group, role, service, or device identifiers to different individuals, groups, roles, services, or devices."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ia-4_obj",
     "label": "IA-04",
     "children": [
      {
       "id": "ia-4_obj.a",
       "label": "IA-04a.",
       "prose": {
        "en": "system identifiers are managed by receiving authorization from {param:ia-04_odp.01} to assign to an individual, group, role, or device identifier;"
       }
      },
      {
       "id": "ia-4_obj.b",
       "label": "IA-04b.",
       "prose": {
        "en": "system identifiers are managed by selecting an identifier that identifies an individual, group, role, service, or device;"
       }
      },
      {
       "id": "ia-4_obj.c",
       "label": "IA-04c.",
       "prose": {
        "en": "system identifiers are managed by assigning the identifier to the intended individual, group, role, service, or device;"
       }
      },
      {
       "id": "ia-4_obj.d",
       "label": "IA-04d.",
       "prose": {
        "en": "system identifiers are managed by preventing reuse of identifiers for {param:ia-04_odp.02}."
       }
      }
     ]
    }
   ],
   "methods": [
    {
