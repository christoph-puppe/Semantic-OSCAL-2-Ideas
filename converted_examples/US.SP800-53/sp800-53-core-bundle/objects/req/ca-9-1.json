{
 "id": "https://ns.nist.gov/sp800-53/req/CA-9.1",
 "version": "5.2.0",
 "label": "CA-9(1)",
 "lifecycle": "active",
 "title": {
  "en": "Compliance Checks"
 },
 "statements": [
  {
   "id": "smt",
   "modality": "must",
   "obligated-parties": [
    "https://ns.nist.gov/sp800-53/party/organization",
    "https://ns.nist.gov/sp800-53/party/system"
   ],
   "prose": {
    "en": "Perform security and privacy compliance checks on constituent system components prior to the establishment of the internal connection."
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/sp800-53/facet/narrative@1": {
   "guidance": [
    {
     "en": "Compliance checks include verification of the relevant baseline configuration."
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/sp800-53a@1": {
   "objectives": [
    {
     "id": "ca-9.1_obj",
     "label": "CA-09(01)",
     "children": [
      {
       "id": "ca-9.1_obj-1",
       "label": "CA-09(01)[01]",
       "prose": {
        "en": "security compliance checks are performed on constituent system components prior to the establishment of the internal connection;"
       }
      },
      {
       "id": "ca-9.1_obj-2",
       "label": "CA-09(01)[02]",
       "prose": {
        "en": "privacy compliance checks are performed on constituent system components prior to the establishment of the internal connection."
       }
      }
     ]
    }
   ],
   "methods": [
    {
     "method": "EXAMINE",
     "label": "CA-09(01)-Examine",
     "objects": [
      {
       "en": "Assessment, authorization, and monitoring policy"
      },
      {
       "en": "access control policy"
      },
      {
       "en": "procedures addressing system connections"
      },
      {
       "en": "system and communications protection policy"
      },
      {
       "en": "system design documentation"
      },
      {
       "en": "system configuration settings and associated documentation"
      },
      {
       "en": "list of components or classes of components authorized as internal system connections"
      },
      {
       "en": "assessment report"
      },
      {
       "en": "system audit records"
      },
      {
       "en": "system security plan"
      },
      {
       "en": "privacy plan"
      },
      {
       "en": "other relevant documents or records"
      }
     ]
    },
    {
     "method": "INTERVIEW",
     "label": "CA-09(01)-Interview",
     "objects": [
      {
       "en": "Organizational personnel with responsibilities for developing, implementing, or authorizing internal system connections"
      },
      {
       "en": "organizational personnel with information security and privacy responsibilities"
      }
     ]
    },
    {
     "method": "TEST",
     "label": "CA-09(01)-Test",
     "objects": [
      {
       "en": "Mechanisms supporting compliance checks"
      }
     ]
    }
   ]
  },
  "https://ns.nist.gov/sp800-53/facet/rmf@1": {
   "contributes-to-assurance": true
  }
 },
