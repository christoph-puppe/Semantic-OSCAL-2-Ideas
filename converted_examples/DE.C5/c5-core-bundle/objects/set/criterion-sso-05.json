   "customer-requirements": [
    {
     "title": "Corresponding Requirements for Cloud Service Customers",
     "prose": {
      "en": "Cloud service customers ensure with suitable controls that they stay informed about subservice organisations of their cloud service provider (e.g. on the basis of the information in the C5 attestation report) and decide on the basis of their protection need of their data processed and stored in the cloud service whether further action should be taken to monitor and check these subservice organisations."
     }
