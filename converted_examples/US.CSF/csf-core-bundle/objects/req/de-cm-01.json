   "prose": {
    "en": "Networks and network services are monitored to find potentially adverse events"
   }
  }
 ],
 "facets": {
  "https://ns.nist.gov/csf/facet/examples@1": {
   "examples": [
    {
     "id": "DE.CM-01.271",
     "prose": {
      "en": "Monitor DNS, BGP, and other network services for adverse events"
     }
    },
    {
     "id": "DE.CM-01.272",
     "prose": {
      "en": "Monitor wired and wireless networks for connections from unauthorized endpoints"
     }
    },
    {
     "id": "DE.CM-01.273",
     "prose": {
      "en": "Monitor facilities for unauthorized or rogue wireless networks"
     }
    },
    {
     "id": "DE.CM-01.274",
     "prose": {
      "en": "Compare actual network flows against baselines to detect deviations"
     }
    },
    {
     "id": "DE.CM-01.275",
     "prose": {
      "en": "Monitor network communications to identify changes in security postures for zero trust purposes"
     }
    }
   ]
  },
  "https://ns.nist.gov/csf/facet/csf@1": {
