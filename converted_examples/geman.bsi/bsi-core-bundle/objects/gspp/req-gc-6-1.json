  "https://ns.bsi.bund.de/facet/gspp-narrative@1": {
   "by-statement": {
    "smt": {
     "guidance": {
      "de": "Der Geltungsbereich legt den formalen und organisatorischen Umfang (Scope) fest, in dem das ISMS angewendet wird. Es wird festgelegt, welche Institutionsbereiche und Tätigkeiten formell zum Geltungsbereich gehören und infrastrukturell abgegrenzt, welche Standorte und Systeme  innerhalb des Geltungsbereichs liegen; welche externen Partner oder Dienstleister in das ISMS einzubeziehen sind und welche Bereiche bewusst nicht Bestandteil des Geltungsbereichs sind."
     }
    }
   }
  }
 },
