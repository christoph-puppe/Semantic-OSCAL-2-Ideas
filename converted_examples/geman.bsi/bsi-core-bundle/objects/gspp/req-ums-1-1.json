   "prose": {
    "de": "Umsetzung MUSS den Umsetzungsstatus der Anforderungen im Anforderungspaket vollständig {param:ums.1.1-prm1} überprüfen."
   },
   "parameters": [
    {
     "name": "ums.1.1-prm1",
     "type": "string",
     "label": "regelmäßig"
    }
   ]
  }
 ],
