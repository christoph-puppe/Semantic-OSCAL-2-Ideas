   "prose": {
    "de": "Beschaffungsmanagement für Einkäufe SOLLTE Security by Default vereinbaren."
   }
  },
  {
   "id": "BES.4.6.1",
   "modality": "should",
   "obligated-parties": [
    "https://ns.bsi.bund.de/gspp/party/institution"
   ],
   "prose": {
    "de": "Beschaffungsmanagement für Dienstleistungen SOLLTE eine Authentifizierung vor dem Zugriff auf schützenswerte Informationen oder Dienste vereinbaren."
   }
  },
  {
   "id": "BES.4.6.2",
   "modality": "should",
   "obligated-parties": [
    "https://ns.bsi.bund.de/gspp/party/institution"
   ],
   "prose": {
    "de": "Beschaffungsmanagement für Outsourcing SOLLTE die Verschlüsselung schützenswerter Informationen durch den Anbieter vereinbaren."
   }
  },
  {
   "id": "BES.4.6.3",
   "modality": "may",
   "obligated-parties": [
    "https://ns.bsi.bund.de/gspp/party/institution"
   ],
   "prose": {
    "de": "Beschaffungsmanagement für IT-Produkte KANN Schutzmechanismen gegen Manipulationen auf dem Lieferweg vereinbaren."
   }
  }
