   "obligated-parties": [
    "https://ns.bsi.bund.de/c3a/party/cloud-dienstanbieter"
   ],
   "prose": {
    "de": "C: Der Cloud-Dienstanbieter muss Cloud-Service-Kunden 90 Tage im Voraus über tatsächliche Änderungen informieren, die die Kontrolle des Cloud-Dienstanbieters betreffen und die mit dem Cloud-Dienst verbundenen C3A-Kontrollen untergraben oder beeinträchtigen könnten, einschließlich wesentlicher Änderungen der Eigentums-, Beteiligungs- oder Governance-Beziehungen des Cloud-Dienstanbieters."
   },
   "parameters": [
    {
     "name": "prm1",
     "type": "string",
