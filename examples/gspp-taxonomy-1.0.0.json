{
  "id": "https://ns.bsi.bund.de/facet/gspp-taxonomy",
  "version": "1.0.0",
  "modifies-semantics": [
    "selection"
  ],
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "sec-level": {
        "enum": [
          "normal-sdt",
          "erhoeht-sdt"
        ]
      },
      "effort": {
        "type": "integer",
        "minimum": 1,
        "maximum": 5
      },
      "tags": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "documentation": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  }
}
